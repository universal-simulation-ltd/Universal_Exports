# Copy this file to .env.local and fill in your Supabase project values.
# Get these from: https://supabase.com/dashboard/project/<your-project>/settings/api

# Canonical (required) — used by both the @unisim/sdk UniversalProvider and the
# app's own Supabase client.
VITE_PLATFORM_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_PLATFORM_SUPABASE_ANON_KEY=your-anon-public-key

# Legacy aliases (optional) — older self-host setups may still use these. The
# app falls back to them when the VITE_PLATFORM_* vars above are not set.
# VITE_SUPABASE_URL=https://your-project-ref.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-public-key
